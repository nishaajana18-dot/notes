Time Decorators 
Our decorator example before allowed us to wrap a function and do what we like with it. What can we do with this ability? We can measure how long function calls take using the following decorator:

import time
from functools import wraps
import threading

_timer_state = threading.local()

def time_decorator(fn):
    @wraps(fn)
    def timed(*args, **kwargs):
        if getattr(_timer_state, 'running', False):
            return fn(*args, **kwargs)
        _timer_state.running = True
        try:
            start = time.time()
            out = fn(*args, **kwargs)
            end = time.time()
            print(f"Ran in {(end - start) * 1000:.0f} ms")
            return out
        finally:
            _timer_state.running = False
    return timed

this will say how much time is needed for the function to produce a return 

@time_decorator
def fib(n): 
    #basecase 
    if n == 0:
        return 0
    elif n == 1:
        return 1
    #recursivecase 
    return fib(n-1) +fib( n-2 )
